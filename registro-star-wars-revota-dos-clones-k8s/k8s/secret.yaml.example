apiVersion: v1
kind: Secret
metadata:
	name: db-credentials
	namespace: registro-atividades-2
type: Opaque
stringData:
	DATABASE_URL: postgresql+psycopg://app_user:app_password@postgres-service:5432/registro_atividades
	POSTGRES_DB: registro_atividades
	POSTGRES_USER: app_user
	POSTGRES_PASSWORD: app_password
	SECRET_KEY: change-me-in-production
.